# Environment Variables Example

# Database (MongoDB)
MONGODB_URI="mongodb+srv://..."
MONGODB_DB_NAME="invoicekit"

# Better Auth
BETTER_AUTH_SECRET="any-32-character-random-string"
BETTER_AUTH_URL="http://localhost:3000" # Your app URL

# Resend (Email)
RESEND_API_KEY="re_..."

# Polar.sh
POLAR_ACCESS_TOKEN="polar_at_..."
POLAR_WEBHOOK_SECRET="whsec_..."
# (Optional) Polar Organization ID if needed for certain API calls
POLAR_ORGANIZATION_ID=""
# Recurring subscription product IDs from Polar
POLAR_MOMENTUM_MONTHLY_ID=""
POLAR_MOMENTUM_YEARLY_ID=""
POLAR_AUTHORITY_MONTHLY_ID=""
POLAR_AUTHORITY_YEARLY_ID=""
